# --- Vite frontend (copy to `.env.local` in repo root) ---
# Your deployed API (no trailing slash):
# VITE_API_BASE_URL=https://libra-api-unique-d4afcbbnb6fdcrgj.centralindia-01.azurewebsites.net

VITE_API_BASE_URL=

# --- Node API (copy to `.env` for local `npm start`) ---

JWT_SECRET=replace-with-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated; defaults include localhost Vite + preview if unset
# CORS_ORIGINS=http://localhost:5173,https://your-frontend.example.com

# Optional Azure Blob (admin cover upload)
# AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=book-covers
