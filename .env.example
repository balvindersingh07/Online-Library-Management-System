# --- Vite frontend (copy to `.env.local` in repo root) ---
# Production / preview: set your deployed API (no trailing slash).
# `npm run dev`: leave this empty OR set Azure below — dev server ignores remote URL
# unless you set VITE_FORCE_REMOTE_API=1 (then calls go straight to Azure).
# VITE_API_BASE_URL=https://your-api.azurewebsites.net
# VITE_FORCE_REMOTE_API=1

VITE_API_BASE_URL=

# Optional: proxy target when using `npm run dev` (default http://127.0.0.1:8000)
# VITE_DEV_API_URL=http://127.0.0.1:8000

# Use mock books + local auth (no server). Overrides dev API default.
# VITE_MOCK_LIBRARY=1

# --- Node API (copy to `.env` for local `npm start`) ---

JWT_SECRET=replace-with-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated; defaults include localhost Vite + preview if unset
# CORS_ORIGINS=http://localhost:5173,https://your-frontend.example.com

# Dev admin auto-seed (see server/README.md). Production: use SEED_DEV_ADMIN=1 once, then 0.
# SEED_DEV_ADMIN=0
# DEV_ADMIN_EMAIL=admin@libra.local
# DEV_ADMIN_PASSWORD=LibraAdmin123!
# DEV_ADMIN_RESYNC=1   # one boot: reset password for existing dev admin email

# Optional Azure Blob (admin cover upload)
# AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=book-covers
