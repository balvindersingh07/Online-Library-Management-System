# Copy to .env and adjust. App loads via pydantic-settings.

# --- App ---
DEBUG=false

# JWT signing (use a long random secret in production)
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
# Local SQLite (default for development)
DATABASE_URL=sqlite:///./library.db

# Azure SQL Database (SQLAlchemy + pyodbc). Install ODBC Driver 18 for SQL Server.
# Example (URL-encode password if it has special characters):
# DATABASE_URL=mssql+pyodbc://USER:PASSWORD@your-server.database.windows.net:1433/your-db?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Azure Blob Storage (optional; omit to disable uploads) ---
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_BLOB_CONTAINER=book-covers
